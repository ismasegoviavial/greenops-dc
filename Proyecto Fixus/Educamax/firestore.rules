rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección 'users'
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reglas para la colección 'materials' (evaluaciones, infografías, rúbricas)
    match /materials/{docId} {
      // Permite leer si el usuario está autenticado y el documento le pertenece
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Permite crear si el usuario asigna su propio userId al nuevo documento
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Permite actualizar o eliminar si el documento le pertenece
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
